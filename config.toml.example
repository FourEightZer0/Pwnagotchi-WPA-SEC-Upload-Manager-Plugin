# Example configuration for Pwnagotchi WPA-SEC Upload Manager Plugin
# Add this section to your Pwnagotchi config.toml

[plugins.upload_manager]
enabled = true

# Required: Your wpa-sec API key (get from https://wpa-sec.stanev.org)
wpa_sec_api_key = "YOUR_API_KEY_HERE"

# Optional: Customize handshake directory
# handshake_dir = "/home/pi/handshakes"

# Optional: Enable/disable auto-uploads
# enable_wpa_sec = true

# Optional: Allow uploading the same SSID multiple times
# allow_duplicate_ssid_uploads = false

# Optional: Scan additional directories for handshakes
# extra_handshake_dirs = ["/root/handshakes"]

# Optional: Minimum file size to upload (bytes)
# min_file_size = 512

# Optional: Minimum file age before eligible for upload (seconds)
# min_file_age = 30

# Optional: Seconds between file scans
# scan_interval = 300

# Optional: Maximum retry attempts per file
# max_retries = 25

# Optional: Seconds to wait before retrying failed uploads
# retry_backoff_seconds = 1800

# Optional: Maximum consecutive errors before pausing uploads
# max_consecutive_errors = 10

# Optional: Recursively scan subdirectories
# scan_recursive = true

# Optional: Rescan files on plugin startup
# startup_rescan = true

# Optional: Default dashboard sort order ("name", "size", or "date")
# web_sort = "name"

# Optional: SSID whitelist (skip uploading these networks)
# whitelist = ["HomeNetwork", "GuestWiFi"]

# Optional: Log file path
# log_path = "/tmp/upload_manager.log"

# Optional: Delete .trigger files after successful upload
# delete_trigger_files = true